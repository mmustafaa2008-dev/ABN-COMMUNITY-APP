# Production frontend — set these in Vercel Dashboard → Environment Variables
# (or copy to .env.production for local prod build / APK)

# Live Express backend URL (Railway / Render / VPS) — HTTPS, no trailing slash.
# MUST respond 200 at {URL}/api/health with "storage":"supabase".
# If this URL 404s, login can still work via Supabase Auth, but directory/API features break.
VITE_API_BASE_URL=https://your-app.up.railway.app

# Required for Vercel auth (register + login use Supabase Auth when set)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy: VITE_SUPABASE_ANON_KEY=eyJ...
