# Production frontend — copy to .env.production before: npm run build
# Replace YOUR_RENDER_URL with your live backend (must be HTTPS)

VITE_API_BASE_URL=https://YOUR_RENDER_URL.onrender.com

# Optional Supabase (if frontend uses Supabase Auth directly)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
