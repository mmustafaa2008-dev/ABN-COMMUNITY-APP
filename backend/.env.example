# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3001

# ── Local dev ─────────────────────────────────────────────────────────────
# FRONTEND_URL=http://192.168.100.13:3000
# LAN_HOST=192.168.100.13

# ── Production (Railway / Render / VPS) ─────────────────────────────────────
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app
# Comma-separated extra origins (Capacitor, staging, etc.)
CORS_ORIGINS=capacitor://localhost,https://your-frontend.vercel.app
# Optional — shown in startup logs
# API_PUBLIC_URL=https://your-api.up.railway.app

# JWT — Generate your own with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit the real .env file. Use this template only.
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_FROM_COMMAND_ABOVE
JWT_EXPIRES_IN=7d

# SQLite database path (relative to backend/) — legacy, unused when STORAGE_MODE=supabase
DB_PATH=./data/directory.db

STORAGE_MODE=supabase

# ── Supabase (@supabase/server — preferred) ───────────────────────────────
# Dashboard → Project Settings → API Keys
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# Legacy JWT keys (still supported if publishable/secret keys are not set)
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional — auto-apply SQL migrations on server startup
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres
