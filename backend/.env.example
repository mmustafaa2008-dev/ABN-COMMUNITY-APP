# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=3001

# ── Local dev ─────────────────────────────────────────────────────────────
# FRONTEND_URL=http://192.168.100.13:3000
# LAN_HOST=192.168.100.13

# ── Production (Render / Railway / VPS) ───────────────────────────────────
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app
# Comma-separated extra origins (Capacitor, staging, etc.)
CORS_ORIGINS=capacitor://localhost,https://your-frontend.vercel.app
# Optional — shown in startup logs
# API_PUBLIC_URL=https://your-api.onrender.com

# JWT — Generate your own with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit the real .env file. Use this template only.
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_FROM_COMMAND_ABOVE
JWT_EXPIRES_IN=7d

# SQLite database path (relative to backend/)
DB_PATH=./data/directory.db

# Set to 'production' on live server
# NODE_ENV=development

# Set to 'memory' only for offline dev without Supabase
STORAGE_MODE=supabase

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL  (do NOT add /rest/v1/ — the SDK appends that automatically)
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / Public key — safe to use in the browser / frontend
# Dashboard → Project Settings → API → "anon public"
SUPABASE_ANON_KEY=your-anon-key-here

# Service Role key — server-side ONLY, bypasses Row Level Security
# Dashboard → Project Settings → API → "service_role secret"
# NEVER expose this to the frontend or commit it to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional — auto-apply SQL migrations on server startup (Dashboard → Settings → Database)
# SUPABASE_DB_PASSWORD=your-database-password
# Or full connection string:
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[project-ref].supabase.co:5432/postgres
