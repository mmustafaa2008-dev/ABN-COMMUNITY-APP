<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production: HTTPS API (Render). Dev builds may use cleartext via manifest. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
